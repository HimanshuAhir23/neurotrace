{
  "manifest_version": 3,
  "name": "NeuroTrace Tracker",
  "version": "1.0",
  "description": "Real-time productivity tracking extension for NeuroTrace",

  "permissions": [
    "tabs",
    "storage",
    "activeTab"
  ],

  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_title": "NeuroTrace Tracker"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}